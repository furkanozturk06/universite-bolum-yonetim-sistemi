# Uygulama portu
PORT=3001

# JWT imzalama anahtarı - KRİTİK. Güçlü, rastgele bir değer kullanın.
# Üretmek için: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=YOUR_JWT_SECRET_HERE

# CORS izinli origin listesi (virgülle ayrılmış)
CORS_ORIGINS=http://localhost:3000

# MySQL bağlantı bilgileri
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=YOUR_DB_PASSWORD_HERE
DB_NAME=ders_programi
